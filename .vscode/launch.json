{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug @gmh-launcher-v0/GMH_Launcher_V0 with Nx",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["nx", "serve", "@gmh-launcher-v0/GMH_Launcher_V0"],
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/apps/GMH_Launcher_V0/dist/**/*.(m|c|)js",
        "!**/node_modules/**"
      ]
    },
